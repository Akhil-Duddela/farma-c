# Farm-C AI — copy to .env (never commit .env)
#   cp .env.example .env
# Fill in your own values; do not use real secrets in this template file in git

NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/farm_c_ai

# Redis (Bull queues)
REDIS_URL=redis://localhost:6379

# Auth & encryption (ENCRYPTION_KEY: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# OpenAI (text + DALL-E)
OPENAI_API_KEY=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PUBLIC_BASE_URL=

# Meta / Instagram Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_GRAPH_VERSION=v21.0
INSTAGRAM_REDIRECT_URI=http://localhost:4000/api/instagram/callback

# YouTube Data API v3 (Google Cloud OAuth)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/youtube/callback

# CORS
CORS_ORIGIN=http://localhost:4200

# Defaults
DEFAULT_TIMEZONE=Asia/Kolkata
MAX_BULK_POSTS=30

# Queue / worker
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_MS=2000
WORKER_CONCURRENCY=5

RUN_QUEUE_IN_API=false
